save-exact=true
# Node is locked to the OpenBMC Yocto toolchain (22.16.0); see package.json
# "//engines". The developer-only @hey-api/openapi-ts codegen tool declares a
# newer Node engine (>=22.18.0). engine-strict=false keeps that a non-blocking
# warning so `npm ci` still succeeds on 22.16.0 (the tool never runs in the
# build/CI; it consumes the committed src/client/).
engine-strict=false
