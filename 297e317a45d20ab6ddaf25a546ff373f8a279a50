      "writtenOn": "2026-03-17T10:44:14Z",
      "side": 1,
      "message": "The cookie check and redirect logic have been moved out of the Login component\u0027s submit handler entirely. The router guard in index.js now handles bouncing already-authenticated users away from /login — if authentication/isLoggedIn is true when navigating to /login, the guard redirects to / immediately, before the component ever renders.",
      "parentUuid": "213ec912_6c817e32",
      "revId": "297e317a45d20ab6ddaf25a546ff373f8a279a50",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
    {
