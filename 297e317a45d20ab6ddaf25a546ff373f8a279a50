      "writtenOn": "2026-03-11T16:52:07Z",
      "side": 1,
      "message": "We should not be doing auth checking on the component.\nWe should not be doing the auth check *after* the user presses the login button in this scenario.\n\nAuthenticationStore.js already has a `isLoggedIn()` function which should have the complete auth check logic.",
      "revId": "297e317a45d20ab6ddaf25a546ff373f8a279a50",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
