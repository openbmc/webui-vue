      },
      "writtenOn": "2026-03-17T10:44:14Z",
      "side": 1,
      "message": "Removed the Cookies.get(\u0027XSRF-TOKEN\u0027) check and the js-cookie import from Login.vue. The login method now always dispatches authentication/login unconditionally. Auth state is owned by the store \"authentication/isLoggedIn\", and the router guard see index.js is responsible for redirecting authenticated users away from \"/login\".",
      "parentUuid": "5ca36a40_30b79d8d",
      "revId": "297e317a45d20ab6ddaf25a546ff373f8a279a50",
      "serverId": "adbd0a64-1f21-4d83-b585-671fe73cb6e4"
    },
