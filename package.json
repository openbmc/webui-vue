{
    "name": "webui-vue",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "OpenBMC Web UI using the Vue.js front-end framework",
    "scripts": {
        "dev": "vite --mode development",
        "serve": "vite --mode development",
        "build-only": "vite build",
        "build:ci": "run-p typecheck:ci build-only",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src scripts golar.config.ts openapi-ts.config.ts tests/unit/redfish-spec-patch.spec.ts",
        "typecheck": "vue-tsc --noEmit",
        "typecheck:ci": "NODE_OPTIONS='--experimental-strip-types --no-warnings' golar typecheck",
        "i18n:report": "vue-i18n-extract report --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/**/*.json'",
        "test": "vitest run",
        "test:unit": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "docs:build": "vuepress build docs",
        "docs:serve": "vuepress dev docs",
        "fetch-spec": "bash scripts/fetch-redfish-spec.sh",
        "openapi-ts:full": "openapi-ts",
        "openapi-ts:scoped": "REDFISH_SCOPE=scoped openapi-ts",
        "prepare": "simple-git-hooks"
    },
    "dependencies": {
        "@carbon/icons-vue": "10.49.1",
        "@novnc/novnc": "1.3.0",
        "@tanstack/vue-query": "5.92.9",
        "@vue/vue3-jest": "27.0.0",
        "@vuelidate/core": "2.0.3",
        "@vuelidate/validators": "2.0.4",
        "axios": "1.13.2",
        "axios-cache-interceptor": "1.11.2",
        "bootstrap": "5.3.8",
        "bootstrap-vue-next": "0.40.8",
        "date-fns": "2.28.0",
        "date-fns-tz": "1.3.6",
        "js-cookie": "3.0.1",
        "lodash": "4.17.21",
        "mitt": "3.0.1",
        "vue": "3.5.24",
        "vue-i18n": "11.2.8",
        "vue-router": "4.6.3",
        "vuex": "4.1.0",
        "xterm": "4.19.0",
        "xterm-addon-attach": "0.6.0",
        "xterm-addon-fit": "0.5.0"
    },
    "devDependencies": {
        "@golar/vue": "0.1.7",
        "@hey-api/openapi-ts": "0.98.2",
        "@types/js-cookie": "3.0.6",
        "@types/pluralize": "0.0.33",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitejs/plugin-basic-ssl": "2.1.3",
        "@vitejs/plugin-vue": "5.2.4",
        "@vitest/coverage-v8": "3.2.4",
        "@vitest/eslint-plugin": "1.1.43",
        "@vue/cli-plugin-babel": "5.0.8",
        "@vue/cli-plugin-eslint": "5.0.8",
        "@vue/cli-plugin-router": "5.0.8",
        "@vue/cli-plugin-unit-jest": "5.0.8",
        "@vue/cli-plugin-vuex": "5.0.8",
        "@vue/cli-service": "5.0.8",
        "@vue/compiler-sfc": "3.5.22",
        "@vue/test-utils": "2.4.5",
        "autoprefixer": "9.8.6",
        "babel-plugin-transform-require-context": "0.1.1",
        "check-node-version": "4.2.1",
        "compression-webpack-plugin": "10.0.0",
        "css-loader": "7.1.1",
        "eslint": "9.18.0",
        "eslint-config-prettier": "10.1.1",
        "eslint-plugin-prettier": "5.1.3",
        "eslint-plugin-vue": "10.0.0",
        "eslint-scope": "7.1.1",
        "file-loader": "6.2.0",
        "globals": "16.0.0",
        "golar": "0.1.7",
        "happy-dom": "18.0.1",
        "jsdom": "26.1.0",
        "lint-staged": "16.0.0",
        "npm-run-all2": "8.0.4",
        "pluralize": "8.0.0",
        "postcss-loader": "8.1.1",
        "prettier": "3.4.2",
        "sass": "1.97.2",
        "sass-loader": "14.2.1",
        "simple-git-hooks": "2.13.1",
        "ts-loader": "9.5.4",
        "typescript": "5.9.3",
        "vite": "6.4.1",
        "vite-plugin-compression": "0.5.1",
        "vite-svg-loader": "5.1.0",
        "vitest": "3.2.4",
        "vue-i18n-extract": "2.0.7",
        "vue-style-loader": "4.1.3",
        "vue-svg-inline-loader": "2.1.5",
        "vue-tsc": "2.2.12",
        "vue3-snapshot-serializer": "2.13.0",
        "vuepress": "1.9.7"
    },
    "//engines": "Node is LOCKED to 22.16.0 to match the OpenBMC Yocto build toolchain (meta-openembedded/meta-oe/recipes-devtools/nodejs/nodejs_22.16.0.bb pins this via the recipe filename). Do NOT bump the Node version: the Yocto build fetches and builds exactly this version. @hey-api/openapi-ts declares a newer Node engine (>=22.18.0), but it is a developer-only codegen tool that never runs in the Yocto build or CI (which only run `npm ci` + `npm run build`/`test:unit` against the committed src/client/). `.npmrc` sets engine-strict=false so its engine warning is non-blocking on 22.16.0; the warning is expected and tolerated. Run codegen on Node >=22.18.0 if needed.",
    "engines": {
        "node": ">=22.16.0"
    },
    "lint-staged": {
        "*.{js,ts,tsx,vue}": [
            "eslint --fix"
        ],
        "*.{md,scss}": [
            "prettier --write"
        ]
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    }
}
